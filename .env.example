# === BenchmarkHub — Environment Variables ===

# REQUIRED: Anthropic API Key for Claude research
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxx

# OPTIONAL: Claude model to use (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# OPTIONAL: Basic Auth (leave empty to disable)
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# OPTIONAL: CORS origins (comma-separated, default: *)
# ALLOWED_ORIGINS=https://benchmark.tudominio.com

# OPTIONAL: Concurrency for web research (default: 2)
# MAX_CONCURRENT_SEARCHES=2

# OPTIONAL: Max retries on API errors (default: 3)
# MAX_RETRIES=3

# OPTIONAL: Directories (defaults work for Docker)
# UPLOAD_DIR=/app/uploads
# OUTPUT_DIR=/app/outputs
# SESSION_DIR=/app/sessions
